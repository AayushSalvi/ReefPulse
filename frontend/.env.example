# Copy to `.env` or `.env.local` in this folder (frontend/). Restart `npm run dev` after changes.
# Keys may also live in the repo root `.env` or `backend/.env` — see vite.config.js.

# Production (Vercel, etc.): public URL of your FastAPI, no trailing slash. Leave empty in dev to use Vite proxy.
# VITE_API_BASE_URL=https://your-api.example.com

# Browser Google Maps (restrict key by HTTP referrer in Google Cloud Console).
VITE_GOOGLE_MAPS_API_KEY=

# Optional alias (same effect if you prefer not to use the VITE_ prefix name).
# GOOGLE_MAPS_API_KEY=
