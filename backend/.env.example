# Copy to `.env` and fill in. Never commit real `.env` (gitignored).

AWS_REGION=us-east-1

# Model B (same account as backend — default credential chain)
SAGEMAKER_ENDPOINT_ANOMALY=reefpulse-model-b
USE_SAGEMAKER_ANOMALY=false

# Model A (cross-account — optional until forecast_service invokes SageMaker)
SAGEMAKER_ENDPOINT_FORECAST=reefpulse-model-a
MODEL_A_AWS_ACCESS_KEY_ID=CHANGEME
MODEL_A_AWS_SECRET_ACCESS_KEY=CHANGEME
MODEL_A_AWS_ACCOUNT_ID=CHANGEME
USE_SAGEMAKER_FORECAST=false

# Model D (cross-account — optional until species_service invokes SageMaker)
SAGEMAKER_ENDPOINT_SPECIES=reefpulse-model-d
MODEL_D_AWS_ACCESS_KEY_ID=CHANGEME
MODEL_D_AWS_SECRET_ACCESS_KEY=CHANGEME
MODEL_D_AWS_ACCOUNT_ID=CHANGEME
USE_SAGEMAKER_SPECIES=false

# Local Model A checkpoint (current default path in forecast_service)
# MODEL_A_ARTIFACT_PATH=/absolute/path/to/model_A_forecaster.pt
